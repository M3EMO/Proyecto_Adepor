{
  "permissions": {
    "allow": [
      "Edit",
      "Write",
      "Bash(*)",
      "Read",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch",
      "TodoWrite",
      "Skill(update-config)",
      "Skill(update-config:*)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(del /f /s /q *)",
      "Bash(format *)",
      "Bash(DROP TABLE*)",
      "Bash(git push --force*)"
    ]
  }
}
